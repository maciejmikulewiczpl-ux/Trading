# MES futures bot config (loaded by futures/run_mes_bot.py). No secrets here -- IBKR auth is the
# Gateway/TWS login, not API keys. Keep DRY_RUN=1 until the paper account + Gateway are verified.

# --- IBKR connection (paper) ---
IB_HOST=127.0.0.1
IB_PORT=4002          # IB Gateway paper=4002, TWS paper=7497 (live=4001/7496 -- do NOT use yet)
IB_CLIENT_ID=17

# --- strategy / risk ---
MES_QTY=1             # contracts per trade (start at 1)
OR_TIGHT_PCTL=0.5     # tight-OR-day gate: trade only days in the tightest N-pctile of OR range
DRY_RUN=1             # 1 = evaluate + log only, NO orders. Set 0 to arm (PAPER account only).
