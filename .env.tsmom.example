# TSMOM sleeve config (loaded by tsmom/rebalance.py). Copy to .env.tsmom and fill in.
# Create a DEDICATED Alpaca PAPER account (free, separate from ORB/news/hype so positions don't mix),
# then paste its paper keys here.
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
TSMOM_CAPITAL=250000   # $ slice to allocate to the sleeve. Safe to SHARE an account: the bot only
                       # trades its own 12 ETFs and sizes off this slice, leaving the rest untouched.
DRY_RUN=1              # 1 = plan + log only, NO orders. Set 0 to arm (PAPER account only).
